{
    "name": "perimeter-registry",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "pnpm generate:themes && next dev --turbopack",
        "build": "pnpm registry:build && pnpm generate:themes && pnpm collect:demos && next build",
        "collect:demos": "tsx scripts/collect-demos.ts",
        "generate:themes": "tsx scripts/generate-theme-css.ts",
        "start": "next start",
        "lint": "eslint .",
        "generate:registry": "tsx scripts/generate-registry.ts",
        "registry:build": "pnpm generate:registry && shadcn build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test": "echo 'No automated tests yet'",
        "quality": "pnpm typecheck && pnpm lint && pnpm format:check"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "embla-carousel-react": "^8.6.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^1.6.0",
        "next": "16.2.1",
        "next-themes": "^0.4.6",
        "react": "19.2.4",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.4",
        "react-resizable-panels": "^4.7.6",
        "recharts": "3.8.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.1",
        "prettier": "^3.8.1",
        "shadcn": "^4.1.0",
        "shiki": "^4.0.2",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5"
    }
}
